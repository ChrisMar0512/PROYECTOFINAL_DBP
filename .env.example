# ============================================================
# ParkShare - Variables de Entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# --- Base de Datos PostgreSQL / PostGIS ---
POSTGRES_DB=parkshare
POSTGRES_USER=parkshare_user
POSTGRES_PASSWORD=parkshare_pass
POSTGRES_PORT=5432

# --- Spring Datasource ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/parkshare
SPRING_DATASOURCE_USERNAME=parkshare_user
SPRING_DATASOURCE_PASSWORD=parkshare_pass

# --- JWT ---
# Secreto de al menos 64 caracteres (Base64 recomendado)
APP_JWT_SECRET=cambia_este_secreto_por_uno_de_al_menos_64_caracteres_aleatorios_seguro
# Expiración en milisegundos (86400000 = 24 horas)
APP_JWT_EXPIRATION=86400000

# --- Firebase ---
# Ruta al archivo de credenciales descargado desde Firebase Console
# Ubicarlo en src/main/resources/ y NO subir al repositorio
FIREBASE_CREDENTIALS_PATH=classpath:firebase-service-account.json
