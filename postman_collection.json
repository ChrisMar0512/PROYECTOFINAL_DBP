					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/reservations/{{reservationId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"reservations",
								"{{reservationId}}"
							]
						},
						"description": "Permite al conductor cancelar una reserva en estado PENDING. La cochera vuelve a estar AVAILABLE y se cancela la expiración."
					},
					"response": []
