{
	"info": {
		"_postman_id": "7662c10b-85e3-4670-bb53-e91c784ee0d8",
		"name": "ParkShare API — Colección Completa",
		"description": "Colección de Postman para el backend de ParkShare. Contiene todos los flujos de Autenticación, Gestión de Cocheras con geolocalización PostGIS, Reservas, Billetera Virtual, Check-in/Check-out con Código QR y Reseñas.\n\n### Configuración Inicial\n1. La variable `baseUrl` apunta a `http://localhost:8080` por defecto.\n2. La variable `token` se actualiza de forma automática al iniciar sesión exitosamente en el endpoint `POST /auth/login` gracias al script de pruebas integrado.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"description": "Módulo de registro e inicio de sesión. No requiere autenticación previa.",
			"item": [
				{
					"name": "Registrar Conductor (DRIVER)",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Christian Conductor\",\n  \"email\": \"driver@parkshare.com\",\n  \"password\": \"SecurePassword123\",\n  \"phone\": \"+51987654321\",\n  \"role\": \"DRIVER\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"register"
							]
						},
						"description": "Registra un nuevo usuario con rol DRIVER (Conductor). Inicializa su billetera virtual en 0.00 de manera automática y publica el evento de bienvenida."
					},
					"response": []
				},
				{
					"name": "Registrar Anfitrión (HOST)",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Christian Anfitrion\",\n  \"email\": \"host@parkshare.com\",\n  \"password\": \"SecurePassword123\",\n  \"phone\": \"+51999999999\",\n  \"role\": \"HOST\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"register"
							]
						},
						"description": "Registra un nuevo usuario con rol HOST (Propietario de cochera)."
					},
					"response": []
				},
				{
					"name": "Iniciar Sesión (Login)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData && jsonData.token) {",
									"    pm.collectionVariables.set(\"token\", jsonData.token);",
									"    console.log(\"Token guardado automáticamente en la variable {{token}}\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"driver@parkshare.com\",\n  \"password\": \"SecurePassword123\",\n  \"fcmToken\": \"fcm-token-test-123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"login"
							]
						},
						"description": "Autentica al usuario con email y contraseña, actualizando opcionalmente su token FCM para notificaciones push. Retorna un JWT válido que se guarda automáticamente en la variable de colección `token`."
					},
					"response": []
				}
			]
		},
