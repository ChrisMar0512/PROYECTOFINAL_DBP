		{
			"name": "Reservations",
			"description": "Módulo para la creación, consulta y cancelación de reservas de estacionamiento.",
			"item": [
				{
					"name": "Crear Reserva (DRIVER)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"parkingSpaceId\": {{parkingSpaceId}}\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/reservations",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"reservations"
							]
						},
						"description": "Crea una reserva en estado PENDING para una cochera disponible. Asigna automáticamente el tiempo de expiración (expiresAt) a 15 minutos en el futuro y cambia el estado de la cochera a RESERVED. Bloquea la cochera con un candado pesimista (PESSIMISTIC_WRITE) para evitar race conditions."
					},
					"response": []
				},
				{
