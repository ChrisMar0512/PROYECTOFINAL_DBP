		{
			"name": "Check-in & Check-out",
			"description": "Proceso físico de ingreso y salida del estacionamiento utilizando códigos QR generados dinámicamente.",
			"item": [
				{
					"name": "Generar Código QR (DRIVER)",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/checkin/generate/{{reservationId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"checkin",
								"generate",
								"{{reservationId}}"
							]
						},
						"description": "Genera el registro del código QR dinámico para la reserva activa con un UUID único y expiración a 30 minutos. Retorna el UUID y la representación gráfica en base64 de la imagen del QR generada con ZXing."
					},
					"response": []
				},
				{
					"name": "Hacer Check-In",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"code\": \"coloca-aqui-el-uuid-del-qr\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/checkin/check-in",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"checkin",
								"check-in"
							]
						},
						"description": "Registra el ingreso del conductor escaneando el código QR de entrada. Valida que el código esté activo, no haya expirado y pertenezca a una reserva PENDING. Actualiza el estado de la reserva a ACTIVE, marca la cochera como OCCUPIED y registra el tiempo de inicio (`startTime`)."
					},
					"response": []
				},
				{
					"name": "Hacer Check-Out",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"code\": \"coloca-aqui-el-uuid-del-qr\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/checkin/check-out",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"checkin",
								"check-out"
							]
						},
						"description": "Registra la salida del vehículo. Valida el código QR, calcula los minutos transcurridos y el costo total de acuerdo con la tarifa por hora, realiza el cobro debitando de la billetera del DRIVER y acreditando a la billetera del HOST (cobro auditado en transacciones), actualiza el estado de la reserva a FINISHED y libera la cochera (AVAILABLE). Envía el email con el resumen del consumo de forma asíncrona."
					},
					"response": []
				}
			]
		},
